# Copy this file to .env.local on the server and fill in real values.
# DO NOT commit .env.local. DO NOT echo the key in logs.

# Sarvam Vision API — only approved cloud call
SARVAM_API_KEY=
SARVAM_VISION_ENDPOINT=https://api.sarvam.ai/v1/vision/extract

# Optional: pin Python path if the sidecar's venv lives elsewhere
# MEDLYNQ_PYTHON=/opt/medlynq/app/.venv/bin/python
