# MedLynQ — Azure environment variables
# Copy to .env.local and fill in values from azure-setup.sh output.
# NEVER commit .env.local to git.

# ── Azure Blob Storage ────────────────────────────────────────────────────────
# Get from: Azure Portal → Storage Account → Access Keys → Connection string
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=medlynqstorage;AccountKey=YOUR_KEY_HERE;EndpointSuffix=core.windows.net"

# Blob container names (created by azure-setup.sh — change only if you renamed them)
AZURE_CONTAINER_REDACTED="medlynq-redacted"
AZURE_CONTAINER_EXTRACTED="medlynq-extracted"

# ── Sarvam Vision (OCR) ───────────────────────────────────────────────────────
# Never commit this key. Set it in Azure Portal → App Service → Configuration.
SARVAM_API_KEY="your-sarvam-api-key"

# ── Python sidecar ────────────────────────────────────────────────────────────
# On Azure App Service (Linux), python3 is the correct binary name
MEDLYNQ_PYTHON="python3"

# ── Next.js ───────────────────────────────────────────────────────────────────
NODE_ENV="production"
NEXT_TELEMETRY_DISABLED="1"
