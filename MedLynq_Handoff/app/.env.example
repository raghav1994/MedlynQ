# Copy this file to .env.local and fill in real values. Never commit .env.local.

# ---------- Database (Postgres) ----------
# Works with Supabase's own Postgres endpoint, Azure Database for PostgreSQL,
# or any Postgres 13+. Get this from Supabase: Settings > Database >
# Connection string (URI tab) — NOT the project URL/service-role key, those
# are for the REST API this app no longer uses.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---------- Session / auth ----------
# Must be >= 32 characters. Generate with: openssl rand -base64 32
IRON_SESSION_SECRET=

# Shared secret for server-to-server calls middleware can't attach a session
# cookie to (nhcx/send -> nhcx/mock). See src/middleware.ts.
MEDLYNQ_INTERNAL_SECRET=

# ---------- Python OCR sidecar ----------
# Absolute path to the Python executable inside app/.venv (created via
# `python -m venv .venv` + `pip install -r python/requirements.txt`).
# Windows: C:\path\to\app\.venv\Scripts\python.exe
# Linux/Docker: /app/.venv/bin/python
MEDLYNQ_PYTHON=

# Number of persistent Python worker processes to keep warm (default 2).
# Each worker holds PaddleOCR/RapidOCR/OnnxTR models in memory — size this to
# available RAM, not CPU core count (each worker is ~1-2GB resident).
MEDLYNQ_WORKER_POOL_SIZE=2

# How many days a redacted document copy is retained before the purge script
# deletes it (compliance/PII minimization).
MEDLYNQ_REDACTED_RETENTION_DAYS=30

# ---------- Sarvam AI (OCR/vision for scanned documents) ----------
SARVAM_API_KEY=
SARVAM_CHAT_MODEL=

# ---------- NHCX (claims submission) ----------
# Local dev/demo defaults to the app's own mock endpoint. Swap to the real
# NHCX gateway URL when going live.
NHCX_ENDPOINT=http://localhost:3000/api/nhcx/mock

# ---------- Multi-tenant (only if deploying one container per hospital) ----------
# When set, locks this deployment to a single tenant instead of resolving one
# per-request from subdomain/session — see db/tenants/*.json for the tenant
# id to use. Leave unset for the shared/multi-tenant deployment model.
# MEDLYNQ_TENANT_ID=

NODE_ENV=production
